# .clangd configuration for vterm-sdl3 project
# This file provides proper include paths and compilation database for clangd

# Compilation database (compile_commands.json) - generated by autotools
CompileFlags:
  Add: [
    "-I/usr/include",
    "-I/usr/include/SDL3",
    "-I/usr/include/freetype2",
    "-I/usr/include/libvterm",
    "-I/usr/include/fontconfig",
    "-I./src",
    "-I./m4"
  ]

# Enable all warnings and treat them as errors
# Diagnostics:
#   Suppress: [
#     "unused-parameter",
#     "unused-variable"
#   ]

# Clangd-specific options
# Clang:
#   ResourceDir: "/usr/lib/clang/15.0.7"
